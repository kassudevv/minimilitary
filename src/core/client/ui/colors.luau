-- Tailwind CSS v4 color palette converted from oklch → sRGB hex.
-- All conversions are mathematically exact (oklch → oklab → linear sRGB → sRGB)

export type Shade = "50" | "100" | "200" | "300" | "400" | "500" | "600" | "700" | "800" | "900" | "950"
-- export type Shade = 50 | 100 | 200 | 300 | 400 | 500 | 600 | 700 | 800 | 900 | 950
export type ColorRamp = { [Shade]: Color3 }
export type Palette = {
	amber: ColorRamp,
	blue: ColorRamp,
	cyan: ColorRamp,
	emerald: ColorRamp,
	fuchsia: ColorRamp,
	gray: ColorRamp,
